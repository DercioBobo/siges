 "doc_type": "Academic Closure",
 "doctype": "Print Format",
 "font": "Default",
 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: 'Arial', sans-serif; font-size: 11px; color: #222; background: #fff; }\n  .pf { padding: 24px 30px; max-width: 780px; margin: 0 auto; }\n  .header { text-align: center; border-bottom: 3px double #333; padding-bottom: 12px; margin-bottom: 16px; }\n  .header h1 { font-size: 18px; letter-spacing: 2px; text-transform: uppercase; font-weight: bold; }\n  .header h2 { font-size: 12px; color: #555; margin-top: 4px; font-weight: normal; }\n  .meta-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; border: 1px solid #ccc; margin-bottom: 16px; }\n  .meta-cell { padding: 6px 10px; border-right: 1px solid #ccc; }\n  .meta-cell:last-child { border-right: none; }\n  .meta-label { font-size: 9px; text-transform: uppercase; color: #777; }\n  .meta-value { font-size: 13px; font-weight: bold; }\n  .summary-band { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; margin-bottom: 16px; }\n  .s-card { border: 1px solid #ddd; border-radius: 3px; padding: 8px; text-align: center; }\n  .s-card .sv { font-size: 20px; font-weight: bold; }\n  .s-card .sl { font-size: 9px; text-transform: uppercase; color: #666; margin-top: 3px; }\n  table.students { width: 100%; border-collapse: collapse; }\n  table.students th { background: #2c3e50; color: #fff; padding: 7px 10px; text-align: left; font-size: 10px; text-transform: uppercase; }\n  table.students th.center { text-align: center; }\n  table.students td { padding: 6px 10px; border-bottom: 1px solid #eee; }\n  table.students td.center { text-align: center; }\n  table.students tr:nth-child(even) td { background: #f8f9fa; }\n  .promovido { color: #1a7a2e; font-weight: bold; }\n  .retido { color: #c0392b; font-weight: bold; }\n  .concluido { color: #2980b9; font-weight: bold; }\n  .footer { margin-top: 30px; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }\n  .sig-line { border-top: 1px solid #333; padding-top: 5px; text-align: center; font-size: 10px; color: #555; }\n  @media print { .pf { padding: 12px; } }\n</style>\n</head>\n<body>\n<div class=\"pf\">\n  <div class=\"header\">\n    <h1>Mapa Final da Turma</h1>\n    <h2>Ano Lectivo: {{ doc.academic_year }}</h2>\n  </div>\n\n  <div class=\"meta-grid\">\n    <div class=\"meta-cell\">\n      <div class=\"meta-label\">Classe</div>\n      <div class=\"meta-value\">{{ doc.school_class }}</div>\n    </div>\n    <div class=\"meta-cell\">\n      <div class=\"meta-label\">Turma</div>\n      <div class=\"meta-value\">{{ doc.class_group }}</div>\n    </div>\n    <div class=\"meta-cell\">\n      <div class=\"meta-label\">Referência</div>\n      <div class=\"meta-value\">{{ doc.name }}</div>\n    </div>\n  </div>\n\n  <div class=\"summary-band\">\n    <div class=\"s-card\">\n      <div class=\"sv\">{{ doc.total_students }}</div>\n      <div class=\"sl\">Total Alunos</div>\n    </div>\n    <div class=\"s-card\">\n      <div class=\"sv promovido\">{{ doc.promoted_students }}</div>\n      <div class=\"sl\">Promovidos</div>\n    </div>\n    <div class=\"s-card\">\n      <div class=\"sv retido\">{{ doc.retained_students }}</div>\n      <div class=\"sl\">Retidos</div>\n    </div>\n    <div class=\"s-card\">\n      <div class=\"sv concluido\">{{ doc.concluded_students }}</div>\n      <div class=\"sl\">Concluídos</div>\n    </div>\n  </div>\n\n  <table class=\"students\">\n    <thead>\n      <tr>\n        <th>Aluno</th>\n        <th class=\"center\" style=\"width:90px\">Média Final</th>\n        <th class=\"center\" style=\"width:120px\">Disciplinas Reprovadas</th>\n        <th class=\"center\" style=\"width:110px\">Decisão Final</th>\n        <th>Observação</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for row in doc.closure_rows %}\n      {% set rn = frappe.db.get_value('Student', row.student, 'full_name') or row.student %}\n      {% set dc = (row.final_decision or '')|lower|replace('í','i')|replace('ú','u') %}\n      <tr>\n        <td>{{ rn }}</td>\n        <td class=\"center\">{{ '%.1f'|format(row.overall_average) if row.overall_average else '—' }}</td>\n        <td class=\"center\">{{ row.total_failed_subjects }}</td>\n        <td class=\"center {{ dc }}\">{{ row.final_decision }}</td>\n        <td>{{ row.remarks or '' }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n\n  {% if doc.notes %}\n  <div style=\"margin-top:16px;border:1px solid #ddd;padding:8px 10px;\">\n    <div style=\"font-size:9px;text-transform:uppercase;color:#777;margin-bottom:4px\">Observações</div>\n    <div style=\"white-space:pre-wrap\">{{ doc.notes }}</div>\n  </div>\n  {% endif %}\n\n  <div class=\"footer\">\n    <div class=\"sig-line\">Director(a) de Turma</div>\n    <div class=\"sig-line\">Direcção da Escola</div>\n  </div>\n</div>\n</body>\n</html>",
 "idx": 0,
 "line_breaks": 0,
